#!/bin/sh /lib/init/init-d-script
### BEGIN INIT INFO
# Provides:          hwaetd
# Required-Start:    $syslog $time $remote_fs
# Required-Stop:     $syslog $time $remote_fs
# Default-Start:     2 3 4 5
# Default-Stop:      0 1 6
# Short-Description: Start hwaetd hostname responder
# Description:       Init script to start the hwaetd hostname responder daemon.
### END INIT INFO
DAEMON=/usr/local/sbin/hwaetd
DESC="Hostname Responder Daemon (hwaetd)"
USER=hwaetd
